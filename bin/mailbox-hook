#!/usr/bin/env python3
"""mailbox-hook — non-consuming peek for runner integration.

Usage:
  mailbox-hook <session_id> <agent_id>
"""

import json, os, sys
from pathlib import Path


def resolve_root():
    return Path(os.environ.get("MAILBOX_ROOT") or
                os.path.expanduser("~/Dropbox/logseq/pages/mi-docs/_mailbox"))


def main(session_id: str, agent_id: str):
    root = resolve_root()
    inbox = root / session_id / agent_id / "inbox"
    if not inbox.exists():
        json.dump({"pending": 0, "messages": []}, sys.stdout)
        sys.exit(0)

    files = [f for f in inbox.glob("*.json")
             if f.is_file() and not f.is_symlink()
             and not f.name.startswith(".sync-conflict-")
             and not f.name.startswith(".tmp-")]

    if not files:
        json.dump({"pending": 0, "messages": []}, sys.stdout)
        sys.exit(0)

    summaries = []
    for f in sorted(files, key=lambda f: f.stat().st_mtime)[:5]:
        try:
            msg = json.loads(f.read_bytes())
            summaries.append({
                "from": msg.get("from", "?"),
                "kind": msg.get("kind", "?"),
                "subject": msg.get("subject", "")[:80],
                "msg_id": msg.get("msg_id", f.stem),
            })
        except (json.JSONDecodeError, UnicodeDecodeError):
            summaries.append({"from": "?", "kind": "?", "subject": "(unreadable)", "msg_id": f.stem})

    result = {"pending": len(files), "messages": summaries}
    json.dump(result, sys.stdout, ensure_ascii=False)
    sys.exit(1 if files else 0)


if __name__ == "__main__":
    if len(sys.argv) < 3:
        print("Usage: mailbox-hook <session_id> <agent_id>", file=sys.stderr)
        sys.exit(2)
    main(sys.argv[1], sys.argv[2])
